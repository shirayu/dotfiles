#!/usr/bin/env python3

import time
import json
from pathlib import Path
from urllib.request import Request, urlopen

auth_path = Path.home() / ".codex" / "auth.json"
token = json.loads(auth_path.read_text())["tokens"]["access_token"]

urls = [
    "https://chatgpt.com/backend-api/wham/rate-limit-reset-credits",
    "https://chatgpt.com/backend-api/wham/usage",
]

outdir = Path.home() / ".codex" / "dump"
outdir.mkdir(exist_ok=True)

for j, url in enumerate(urls):
    if j > 0:
        time.sleep(1)

    req = Request(
        url,
        headers={"Authorization": f"Bearer {token}", "Accept": "application/json"},
    )

    data = json.loads(urlopen(req, timeout=30).read())

    with (outdir / (Path(url).name + ".json")).open("w") as outf:
        outf.write(json.dumps(data, indent=2))
        outf.write("\n")
