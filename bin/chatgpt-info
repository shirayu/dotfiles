#!/usr/bin/env python3
"""Fetch and pretty-print ChatGPT/Codex usage & rate-limit-reset-credit info.

Use --cache to skip re-downloading and just render the last dump in
~/.codex/dump/.
"""

import argparse
import json
import sys
import time
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from urllib.request import Request, urlopen

DUMP_DIR = Path.home() / ".codex" / "dump"
AUTH_PATH = Path.home() / ".codex" / "auth.json"

ENDPOINTS = {
    "rate-limit-reset-credits.json": "https://chatgpt.com/backend-api/wham/rate-limit-reset-credits",
    "usage.json": "https://chatgpt.com/backend-api/wham/usage",
}


class Ansi:
    enabled = sys.stdout.isatty()

    @classmethod
    def wrap(cls, code, s):
        return f"\033[{code}m{s}\033[0m" if cls.enabled else str(s)

    @classmethod
    def bold(cls, s):
        return cls.wrap("1", s)

    @classmethod
    def dim(cls, s):
        return cls.wrap("2", s)

    @classmethod
    def red(cls, s):
        return cls.wrap("31", s)

    @classmethod
    def green(cls, s):
        return cls.wrap("32", s)

    @classmethod
    def visible_len(cls, s):
        """Length ignoring ANSI escape codes, for column alignment."""
        out, in_esc = 0, False
        for ch in s:
            if ch == "\033":
                in_esc = True
            elif in_esc:
                in_esc = ch != "m"
            else:
                out += 1
        return out


def parse_ts(value):
    """Parse an epoch-seconds number or ISO-8601 string into an aware UTC datetime."""
    if value is None:
        return None
    if isinstance(value, (int, float)):
        return datetime.fromtimestamp(value, tz=timezone.utc)
    try:
        return datetime.fromisoformat(str(value).replace("Z", "+00:00"))
    except ValueError:
        return None


def fmt_ts(value):
    dt = parse_ts(value)
    return dt.astimezone().strftime("%Y-%m-%d %H:%M:%S %Z") if dt else "-"


def fmt_duration(seconds):
    if seconds is None:
        return "-"
    seconds = int(seconds)
    days, seconds = divmod(seconds, 86400)
    hours, seconds = divmod(seconds, 3600)
    minutes, seconds = divmod(seconds, 60)
    clock = f"{hours:02}:{minutes:02}:{seconds:02}"
    return f"{days}d {clock}" if days else clock


def color_by_urgency(seconds, text):
    """Color where LESS time left is worse (e.g. a voucher about to expire)."""
    if seconds <= 0:
        return Ansi.red(text)
    if seconds < 86400:
        return Ansi.red(text)
    if seconds < 3 * 86400:
        return Ansi.wrap("33", text)
    return Ansi.green(text)


def color_by_relief(seconds, text):
    """Color where MORE time left is worse (e.g. time until a rate limit resets)."""
    if seconds < 86400:
        return Ansi.green(text)
    if seconds < 3 * 86400:
        return Ansi.wrap("33", text)
    return Ansi.red(text)


def fmt_days(seconds):
    if seconds is None:
        return "-"
    return f"{int(seconds) // 86400}d"


def fmt_time_until(value):
    dt = parse_ts(value)
    if dt is None:
        return "-"
    remaining = (dt - datetime.now(timezone.utc)).total_seconds()
    text = "expired" if remaining <= 0 else fmt_duration(remaining)
    return color_by_urgency(remaining, text)


def fmt_pct(p):
    if p is None:
        return "-"
    color = Ansi.red if p >= 90 else (lambda s: Ansi.wrap("33", s)) if p >= 50 else Ansi.green
    return color(f"{p}%")


def short_id(full_id):
    return full_id.rsplit("_", 1)[-1][:10]


class Table:
    def __init__(self, headers):
        self.headers = headers
        self.rows = []

    def add_row(self, *cells):
        self.rows.append([str(cell) for cell in cells])

    def print(self):
        widths = [len(h) for h in self.headers]
        for row in self.rows:
            for i, cell in enumerate(row):
                widths[i] = max(widths[i], Ansi.visible_len(cell))

        def rule():
            print("+" + "+".join("-" * (w + 2) for w in widths) + "+")

        def print_row(cells):
            padded = [f" {cell}{' ' * (w - Ansi.visible_len(cell))} " for cell, w in zip(cells, widths)]
            print("|" + "|".join(padded) + "|")

        rule()
        print_row([Ansi.bold(h) for h in self.headers])
        rule()
        for row in self.rows:
            print_row(row)
        rule()


def section(title):
    print()
    print(Ansi.bold(title))


def fetch(outdir, sleep:float,):
    token = json.loads(AUTH_PATH.read_text())["tokens"]["access_token"]
    outdir.mkdir(parents=True, exist_ok=True)

    for i, (filename, url) in enumerate(ENDPOINTS.items()):
        if i > 0:
            time.sleep(sleep)
        req = Request(url, headers={"Authorization": f"Bearer {token}", "Accept": "application/json"})
        data = json.loads(urlopen(req, timeout=30).read())
        (outdir / filename).write_text(json.dumps(data, indent=2) + "\n")


def load_json(path):
    try:
        return json.loads(path.read_text())
    except FileNotFoundError:
        return None
    except json.JSONDecodeError as e:
        print(f"(failed to parse {path.name}: {e})", file=sys.stderr)
        return None


@dataclass
class Dump:
    usage: dict
    reset_credits: dict


def load_dump(dump_dir):
    usage = load_json(dump_dir / "usage.json") or {}
    reset_credits = load_json(dump_dir / "rate-limit-reset-credits.json") or {}
    if not usage and not reset_credits:
        print(f"No dump files found in {dump_dir}", file=sys.stderr)
        sys.exit(1)
    return Dump(usage=usage, reset_credits=reset_credits)


def print_account_line(usage):
    limit_reached = (usage.get("rate_limit") or {}).get("limit_reached")
    status = Ansi.bold(Ansi.red("LIMIT REACHED")) if limit_reached else Ansi.green("ok")
    print(f"{Ansi.bold(usage.get('email', '-'))}  plan={usage.get('plan_type', '-')}  status={status}")


def print_rate_limits(usage):
    section("Rate limits")
    table = Table(["limit", "window", "used", "period", "resets in", "reset at"])

    def add_windows(label, rate_limit):
        for win_name in ("primary_window", "secondary_window"):
            win = (rate_limit or {}).get(win_name)
            if win is None:
                continue
            reset_after = win.get("reset_after_seconds")
            table.add_row(
                label,
                win_name.removesuffix("_window"),
                fmt_pct(win.get("used_percent")),
                fmt_days(win.get("limit_window_seconds")),
                color_by_relief(reset_after, fmt_duration(reset_after)) if reset_after is not None else "-",
                fmt_ts(win.get("reset_at")),
            )

    add_windows("default", usage.get("rate_limit"))
    for extra in usage.get("additional_rate_limits") or []:
        add_windows(extra.get("limit_name", "-"), extra.get("rate_limit"))

    if table.rows:
        table.print()
    else:
        print("  (none)")


def print_credits(usage):
    section("Credits")
    credits = usage.get("credits") or {}
    reset_credits = usage.get("rate_limit_reset_credits") or {}

    table = Table(["balance", "has_credits", "unlimited", "reset_credits avail", "reset_credits applicable"])
    table.add_row(
        credits.get("balance", "-"),
        credits.get("has_credits", "-"),
        credits.get("unlimited", "-"),
        reset_credits.get("available_count", "-"),
        reset_credits.get("applicable_available_count", "-"),
    )
    table.print()

    upsell = usage.get("rate_limit_upsell")
    if upsell:
        print(f"  {Ansi.dim(upsell.get('title', ''))}: {upsell.get('description', '')}")


def print_vouchers(reset_credits):
    section(f"Reset-credit vouchers (earned total: {reset_credits.get('total_earned_count', 0)})")
    table = Table(["id", "status", "type", "granted", "expires", "expires in", "redeemed"])

    for voucher in reset_credits.get("credits") or []:
        status = voucher.get("status", "")
        status_disp = Ansi.green(status) if status == "available" else status
        table.add_row(
            short_id(voucher.get("id", "")),
            status_disp,
            voucher.get("reset_type", "-"),
            fmt_ts(voucher.get("granted_at")),
            fmt_ts(voucher.get("expires_at")),
            fmt_time_until(voucher.get("expires_at")),
            fmt_ts(voucher.get("redeemed_at")),
        )

    if table.rows:
        table.print()
    else:
        print("  (none)")


def render(dump_dir):
    dump = load_dump(dump_dir)
    print_account_line(dump.usage)
    print_rate_limits(dump.usage)
    print_vouchers(dump.reset_credits)
    print_credits(dump.usage)
    print()


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--cache", action="store_true",
        help="skip re-downloading; render the existing dump in ~/.codex/dump/",
    )
    parser.add_argument(
        "--sleep", type=float, default=0.1,
        help="sleep time",
    )
    args = parser.parse_args()

    if not args.cache:
        fetch(DUMP_DIR, args.sleep)

    render(DUMP_DIR)


if __name__ == "__main__":
    main()
