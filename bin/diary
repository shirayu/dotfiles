#!/usr/bin/env python3
import argparse
import re
import subprocess
from datetime import datetime, timedelta
from pathlib import Path
from typing import Optional


def parse_date(date_str: str, today: Optional[datetime] = None) -> datetime:
    """Parse various string formats into a datetime object."""
    today = today or datetime.now()
    date_str = date_str.lower()

    if date_str in ("today", "tod"):
        return today
    elif date_str in ("yesterday", "yes", "y"):
        return today - timedelta(days=1)
    elif date_str in ("tomorrow", "tom", "t"):
        return today + timedelta(days=1)
    elif re.fullmatch(r"[+-]\d+", date_str):
        return today + timedelta(days=int(date_str))

    # Supported date formats (ordered by priority)
    formats = {
        r"\d{4}-\d{2}-\d{2}": ("%Y-%m-%d", date_str),  # 2026-06-02
        r"\d{8}": ("%Y%m%d", date_str),  # 20260602
        r"\d{2}-\d{2}": ("%Y-%m-%d", f"{today.year}-{date_str}"),  # 06-02
        r"\d{4}": ("%Y%m%d", f"{today.year}{date_str}"),  # 0602
    }

    for pattern, (fmt, value) in formats.items():
        if re.fullmatch(pattern, date_str):
            try:
                return datetime.strptime(value, fmt)
            except ValueError:
                break

    if re.fullmatch(r"\d{1,2}", date_str):
        try:
            return datetime(today.year, today.month, int(date_str))
        except ValueError:
            pass

    raise argparse.ArgumentTypeError(
        f"Invalid date format: '{date_str}'. "
        f"Use today/y/t, +1/-1, YYYYMMDD, MMDD, or YYYY-MM-DD."
    )


def diary_file_path(root: Path, target_date: datetime) -> Path:
    """Return the diary file path for the target date."""
    return (
        root
        / target_date.strftime("%Y")
        / target_date.strftime("%m")
        / f"{target_date.strftime('%d')}.md"
    )


def ensure_diary_file(root: Path, target_date: datetime) -> Path:
    """Create the diary file if needed and return its path."""
    file_path = diary_file_path(root, target_date)
    file_path.parent.mkdir(parents=True, exist_ok=True)

    if not file_path.exists():
        file_path.write_text(
            f"# {target_date.strftime('%Y-%m-%d')}\n\n",
            encoding="utf-8",
        )

    return file_path


def main():
    parser = argparse.ArgumentParser(
        description="A simple CLI tool to manage daily markdown diaries."
    )
    parser.add_argument(
        "date",
        nargs="?",
        default="today",
        help="Target date (e.g., today, y, t, +1, -1, 0601, 2026-06-01). Defaults to today.",
    )
    parser.add_argument(
        "-r",
        "--root",
        type=Path,
        default=Path.home() / "secret" / "diary",
        help="Target root dir",
    )
    parser.add_argument(
        "--cmd",
        type=Path,
        default="nvim",
    )
    parser.add_argument(
        "--arg",
        default="+",
    )
    args = parser.parse_args()

    try:
        target_date = parse_date(args.date) if isinstance(args.date, str) else args.date
    except argparse.ArgumentTypeError as e:
        print(f"Error: {e}")
        return

    file_path = ensure_diary_file(args.root, target_date)

    # Open positioning the cursor at the end of the file
    subprocess.run([args.cmd, args.arg, str(file_path)])


if __name__ == "__main__":
    main()
