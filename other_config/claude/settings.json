{
  "cleanupPeriodDays": 3650,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [],
    "deny": []
  },
  "alwaysThinkingEnabled": false,
  "autoMemoryEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.local/bin/claude-statusline.sh\""
  }
}
